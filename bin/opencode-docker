#!/usr/bin/env bash

# Determine git root and compute hash
if git rev-parse --show-toplevel >/dev/null 2>&1; then
	GIT_ROOT=$(git rev-parse --show-toplevel)
	HASH=$(echo -n "$GIT_ROOT" | sha1sum | cut -c1-8)
	MOUNT_SRC="$GIT_ROOT"
else
	HASH=$(echo -n "$PWD" | sha1sum | cut -c1-8)
	MOUNT_SRC="$PWD"
fi

hash_name_map_file=~/.opencode_map
if ! grep -q "^opencode-$HASH:" "$hash_name_map_file" 2>/dev/null
then
	echo "opencode-$HASH:$MOUNT_SRC" >> "$hash_name_map_file"
fi

# Run docker container with name based on hash
set -e

# Compute container name based on project hash (same as before)
CONTAINER_NAME="opencode-$HASH"

# Resolve the repo root (follow symlinks so `claude`/`claude-yolo` symlinks still find the right dir)
script="$0"
while [ -L "$script" ]; do
	dir="$(cd "$(dirname "$script")" && pwd)"
	script="$(readlink "$script")"
	[[ "$script" != /* ]] && script="$dir/$script"
done
YOLO_REPO_ROOT="$(cd "$(dirname "$script")/.." && pwd)"

is_container_stale() {
	local current_image_id container_image_id
	current_image_id=$(docker image inspect opencode-dev:latest --format '{{.Id}}' 2>/dev/null) || return 1
	container_image_id=$(docker inspect --format '{{.Image}}' "$CONTAINER_NAME" 2>/dev/null) || return 1
	[[ "$current_image_id" != "$container_image_id" ]]
}

has_active_exec_sessions() {
	local exec_ids
	exec_ids=$(docker inspect --format '{{json .ExecIDs}}' "$CONTAINER_NAME" 2>/dev/null)
	[[ "$exec_ids" != "null" && -n "$exec_ids" ]]
}

ensure_dummy_container() {
	local need_restart=
	if docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
		if is_container_stale; then
			if has_active_exec_sessions; then
				echo "Warning: Container ${CONTAINER_NAME} uses an outdated image but has active sessions." >&2
				read -r -p "Force replace? Active sessions will be terminated. [y/N] " answer
				if [[ "$answer" =~ ^[Yy]$ ]]; then
					echo "Replacing container ${CONTAINER_NAME}…"
					need_restart=1
				else
					echo "Continuing with outdated container." >&2
				fi
			else
				echo "Container ${CONTAINER_NAME} uses an outdated image. Replacing…"
				need_restart=1
			fi
		fi

		if [ -n "$need_restart" ]
		then
			docker kill "${CONTAINER_NAME}" >/dev/null 2>&1 || docker rm -f "${CONTAINER_NAME}" >/dev/null
			start_dummy_container
		fi
	else
		start_dummy_container
	fi
}

start_dummy_container() {
	# Ensure claude.json exists as a regular file so Docker doesn't create it as a directory
	[[ -f "${YOLO_REPO_ROOT}/claude.json" ]] || touch "${YOLO_REPO_ROOT}/claude.json"
	[[ -f "${YOLO_REPO_ROOT}/env" ]] || touch "${YOLO_REPO_ROOT}/env"

	echo "Launching dummy container ${CONTAINER_NAME}…"
	docker run --rm -d --name "${CONTAINER_NAME}" \
		--add-host=host.docker.internal:host-gateway \
		--network yolo-container-net \
		-e HOST_UID="$(id -u)" -e HOST_GID="$(id -g)" \
		-v "${MOUNT_SRC}:/code-$HASH" \
		-v "${YOLO_REPO_ROOT}/claude:/home/dev/.claude" \
		-v "${YOLO_REPO_ROOT}/claude.json:/home/dev/.claude.json" \
		-v "${YOLO_REPO_ROOT}/env:/home/dev/.env" \
		-v "$HOME/.local/share/opencode":/home/dev/.local/share/opencode \
		--workdir /code-"$HASH" \
		opencode-dev:latest tail -f /dev/null
	docker exec "$CONTAINER_NAME" flock -x /.ready -c true
}

# Ensure dummy container is up
ensure_dummy_container

if [[ "$1" = "sh" || "$1" == "bash" || "$1" = "claude" ]]
then
	cmd=("$1")
	shift
elif [[ "$0" == *"/claude" ]]
then
	cmd=(claude --permission-mode auto --model opus)
elif [[ "$0" == *"/claude-docker" || "$0" == *"/claude-yolo" ]]
then
	cmd=(claude --dangerously-skip-permissions)
else
	cmd=(opencode)
fi

exec docker exec -it --user "$(id -u):$(id -g)" --env-file "${YOLO_REPO_ROOT}/env" "${CONTAINER_NAME}" "${cmd[@]}" "$@"
