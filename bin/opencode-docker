#!/usr/bin/env bash
#
# Compatibility shim. The launcher is now bin/yo; new usage should call `yo`
# directly (yo claude / yo -y / yo sh / yo status …). This script only exists so
# the legacy symlink interface keeps working: symlink it as `claude`,
# `claude-docker`, `claude-yolo`, `codex`, `codex-docker`, `codex-yolo`, or
# `opencode-docker` and it forwards to the matching `yo` invocation.
#
# See README.md / CLAUDE.md for the mapping.

set -e

# Resolve bin/yo next to this (possibly symlinked) script.
script="$0"
while [ -L "$script" ]; do
	dir="$(cd "$(dirname "$script")" && pwd)"
	script="$(readlink "$script")"
	[[ "$script" != /* ]] && script="$dir/$script"
done
YO="$(cd "$(dirname "$script")" && pwd)/yo"

# A `sh`/`bash`/`claude` first argument takes precedence over the invoked name,
# matching the legacy dispatch order.
case "${1:-}" in
	sh|bash) shell="$1"; shift; exec "$YO" exec "$shell" "$@" ;;
	claude)  shift;             exec "$YO" --safe claude "$@" ;;
esac

# Otherwise pick tool + mode from the name the script was invoked as.
case "$0" in
	*/codex-docker|*/codex)    exec "$YO" codex "$@" ;;
	*/codex-yolo)              exec "$YO" -y codex "$@" ;;
	*/claude-docker|*/claude)  exec "$YO" -m opus claude "$@" ;;
	*/claude-yolo)             exec "$YO" -y claude "$@" ;;
	*)                         exec "$YO" opencode "$@" ;;
esac
